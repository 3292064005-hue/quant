include README.md
include LICENSE
include NOTICE_THIRD_PARTY.md
include requirements.txt
include ruff.toml
include mypy.ini
recursive-include docs *.md
recursive-include configs *.yaml
recursive-include sample_data *.csv
recursive-include tests *.py
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .coverage*
prune build
prune dist
prune .git
prune runtime
prune .pytest_cache
prune .mypy_cache
prune .ruff_cache
prune .venv
prune a_share_quant_workstation.egg-info
prune .out_staging
